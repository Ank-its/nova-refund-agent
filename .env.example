# --- LLM provider -----------------------------------------------------------
# Choose one provider and set its matching API key below.
#   openai | anthropic | google
LLM_PROVIDER=openai
# Optional: pin a specific model. Leave blank to use the provider default
#   openai    -> gpt-4o-mini
#   anthropic -> claude-3-5-haiku-latest
#   google    -> gemini-1.5-flash
LLM_MODEL=

OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Signs auth tokens. Set a long random value in production so sessions survive
# restarts and tokens can't be forged. e.g. `openssl rand -hex 32`.
SECRET_KEY=nova-dev-secret-change-me

# --- Database (Nova) --------------------------------------------------------
POSTGRES_USER=nova_user
POSTGRES_PASSWORD=nova_pass_2024
POSTGRES_DB=nova
DATABASE_URL=postgresql+asyncpg://nova_user:nova_pass_2024@postgres_db:5432/nova
